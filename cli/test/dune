(melange.emit
 (target jest)
 (modules test_support test_cases fake_codex)
 (module_systems commonjs)
 (libraries melange-jest.jest melange.node)
 (preprocess
  (pps melange.ppx)))

(rule
 (alias runtest)
 (deps
  (alias ../bin/melange)
  (alias ./melange)
  jest/test/test_cases.js
  jest/test/fake_codex.js
  ../bin/logseq_cli_melange/bin/main.js)
 (action
  (setenv LOGSEQ_CLI_MELANGE_ENTRYPOINT bin/logseq_cli_melange/bin/main.js
   (chdir
    %{workspace_root}
    (run
     npx
     jest
     --testMatch
     **/_build/default/test/jest/test/test_cases.js)))))
