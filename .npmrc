# Do NOT enable shamefully-hoist by default.
# It is a last-resort compatibility fallback because it effectively hoists
# almost everything to the root node_modules (similar to setting
# public-hoist-pattern[]=*), which can hide undeclared / phantom dependency issues.
#
# If a tool fails under pnpm with errors such as:
# - Cannot find module 'xxx'
# - ERR_MODULE_NOT_FOUND
# - a Babel / ESLint / loader / preset / plugin package only works when its
#   dependencies are available from the root node_modules
#
# then prefer targeted public hoisting first:
#   public-hoist-pattern[]=*eslint*
#   public-hoist-pattern[]=*babel*
#   public-hoist-pattern[]=*plugin*
# or add a more specific pattern for the actual failing package.
#
# Only use shamefully-hoist=true if targeted publicHoistPattern entries are
# still not enough, or if many legacy / broken tools depend on root-level
# hoisting and the narrower fix becomes impractical.
shamefully-hoist=false

# Enforce deterministic installs by preferring the existing lockfile.
# pnpm will use pnpm-lock.yaml as the single source of truth and will
# fail the install if package.json changes are not reflected in the lockfile.
#
# This helps prevent:
# - accidental lockfile updates during local installs
# - dependency drift between developers or CI environments
# - non-reproducible builds across Windows / Linux / macOS
#
# To intentionally update dependencies, run:
#   pnpm install --no-frozen-lockfile
#
# Recommended for team projects, CI pipelines, and cross-platform setups.
prefer-frozen-lockfile=true
