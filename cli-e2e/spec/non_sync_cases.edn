    {:global ["--config" "--graph" "--root-dir" "--output"],
     :upsert ["--page" "--update-tags" "--update-properties"]}},
   :tags [:upsert],
   :extends :non-sync/graph-json-env}
  {:id "node-list-by-tags-properties-json",
