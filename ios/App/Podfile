target 'Logseq' do
  capacitor_pods
  # Add your Pods here
  pod 'Drops', :git => 'https://github.com/omaralbeik/Drops.git', :tag => '1.7.0'
end


post_install do |installer|
  assertDeploymentTarget(installer)
end
